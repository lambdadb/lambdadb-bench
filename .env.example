# Copy this file to .env and fill in only the targets you want to validate.
# .env is ignored by git.

# LambdaDB integration test gate.
LAMBDADB_BENCH_RUN_INTEGRATION=0
LAMBDADB_ENDPOINT=https://api.lambdadb.ai
LAMBDADB_PROJECT_NAME=
LAMBDADB_API_KEY=
LAMBDADB_COLLECTION_NAME=

# Qdrant Cloud integration test gate.
QDRANT_BENCH_RUN_INTEGRATION=0
QDRANT_ENDPOINT=
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=

# Pinecone Serverless integration test gate.
PINECONE_BENCH_RUN_INTEGRATION=0
PINECONE_API_KEY=
PINECONE_INDEX_NAME=
PINECONE_INDEX_HOST=
PINECONE_REGION=us-east-1
